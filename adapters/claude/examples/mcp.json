{
  "_readme": "Copy this file to your project root as .mcp.json. Remove the servers you don't need. Replace ${VAR} placeholders with real values via environment variables — never hardcode credentials here.",

  "mcpServers": {

    "_issue_tracker_pick_one": "Configure ONE of: github, linear, or jira. Delete the others.",

    "github": {
      "_abstract_tool": "issue-tracker",
      "_agents": ["business-analyst", "technical-architect"],
      "_mcp_server": "@modelcontextprotocol/server-github",
      "_source": "https://github.com/modelcontextprotocol/servers/tree/main/src/github",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },

    "linear": {
      "_abstract_tool": "issue-tracker",
      "_agents": ["business-analyst", "technical-architect"],
      "_mcp_server": "@linear/mcp-server",
      "_source": "https://github.com/modelcontextprotocol/servers",
      "command": "npx",
      "args": ["-y", "@linear/mcp-server"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    },

    "jira": {
      "_abstract_tool": "issue-tracker",
      "_agents": ["business-analyst", "technical-architect"],
      "_mcp_server": "@sooperset/mcp-atlassian",
      "_source": "https://github.com/sooperset/mcp-atlassian",
      "command": "npx",
      "args": ["-y", "@sooperset/mcp-atlassian"],
      "env": {
        "JIRA_URL": "${JIRA_URL}",
        "JIRA_EMAIL": "${JIRA_EMAIL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
      }
    },

    "_database_pick_one": "Configure ONE of: postgres, sqlite, or mysql. Delete the others.",

    "postgres": {
      "_abstract_tool": "database",
      "_agents": ["security-engineer", "devops-engineer", "sre"],
      "_mcp_server": "@modelcontextprotocol/server-postgres",
      "_source": "https://github.com/modelcontextprotocol/servers/tree/main/src/postgres",
      "_note": "Use a read-only DB user by default. Create a separate user for write operations.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${DATABASE_URL}"]
    },

    "sqlite": {
      "_abstract_tool": "database",
      "_agents": ["security-engineer", "devops-engineer", "sre"],
      "_mcp_server": "@modelcontextprotocol/server-sqlite",
      "_source": "https://github.com/modelcontextprotocol/servers/tree/main/src/sqlite",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "${SQLITE_DB_PATH}"]
    },

    "mysql": {
      "_abstract_tool": "database",
      "_agents": ["security-engineer", "devops-engineer", "sre"],
      "_mcp_server": "mcp-server-mysql",
      "_source": "https://github.com/benborla/mcp-server-mysql",
      "command": "npx",
      "args": ["-y", "mcp-server-mysql"],
      "env": {
        "MYSQL_HOST": "${MYSQL_HOST}",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "${MYSQL_USER}",
        "MYSQL_PASSWORD": "${MYSQL_PASSWORD}",
        "MYSQL_DATABASE": "${MYSQL_DATABASE}"
      }
    },

    "_communication_optional": "Slack is optional. Omit if agents should produce messages as documents rather than sending them directly.",

    "slack": {
      "_abstract_tool": "communication",
      "_agents": ["business-analyst", "sre"],
      "_mcp_server": "@modelcontextprotocol/server-slack",
      "_source": "https://github.com/modelcontextprotocol/servers/tree/main/src/slack",
      "_note": "Messages post to real channels. Confirm target channel before the agent sends during incidents.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    }

  }
}
